# pnpm security defaults for GramartEnglish backend.
# These run as defaults whenever someone uses pnpm in this directory.

# Block ALL lifecycle scripts by default (postinstall, preinstall, etc.).
# Specific packages that legitimately need them are allowlisted via the
# `pnpm.onlyBuiltDependencies` field in package.json.
ignore-scripts=false
side-effects-cache=false

# Lockfile policy:
#   - In CI: pnpm defaults to frozen-lockfile=true automatically (env CI=true).
#   - In local dev: we let pnpm update the lockfile when package.json changes.
# We intentionally do NOT set frozen-lockfile=true here, because that would
# also block the very first install (when no lockfile exists yet).

# Require dependencies declared in package.json — no phantom imports.
strict-peer-dependencies=true

# Hardlinks to the global store; safer + space-efficient.
node-linker=hoisted

# Don't auto-install peer deps that weren't asked for.
auto-install-peers=false

# Verify package integrity against the registry on every install.
verify-store-integrity=true

# Allow scripts only from the allowlist in package.json -> pnpm.onlyBuiltDependencies.
# (pnpm enforces this when the field is present.)
