[
  { "base": "acquire", "pos": "verb", "level": "B2", "spanishOption": "adquirir / obtener", "canonicalDefinition": "To get or obtain something, especially through effort.", "canonicalExamples": ["She acquired a new skill."], "sourceTag": "author" },
